# SpacetimeDB (optional — defaults used if unset)
# VITE_SPACETIMEDB_HOST=ws://localhost:3000
# VITE_SPACETIMEDB_DB_NAME=zovid-cexwd

# LiveKit proximity voice — required for /api/livekit-token (set in Vercel for prod, .env.local for local)
# Production:
# LIVEKIT_URL=wss://voice.yourdomain.com
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret
# Local (with: docker run ... LIVEKIT_KEYS="devkey: secret" ... --dev  and  npx vercel dev):
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# Optional: base URL for token API (defaults to window.location.origin)
# VITE_APP_URL=https://your-app.vercel.app

# Donation / Support (optional — Support button hidden if both are unset)
# VITE_KOFI_URL=https://ko-fi.com/yourname
# VITE_DONATION_BITCOIN_ADDRESS=
